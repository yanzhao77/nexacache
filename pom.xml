<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.nexacache</groupId>
    <artifactId>nexacache-parent</artifactId>
    <version>2.0.0</version>
    <packaging>pom</packaging>
    <name>NexaCache Parent</name>
    <description>NexaCache - 注解驱动的高性能指针式内存缓存框架（JDK 25 LTS）</description>

    <modules>
        <module>nexacache-core</module>
        <module>nexacache-adapter-mybatis</module>
        <module>nexacache-spring-boot-starter</module>
        <module>nexacache-demo</module>
        <module>nexacache-benchmark</module>
    </modules>

    <properties>
        <java.version>25</java.version>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- Spring Boot 3.5.3（最新稳定版，支持 JDK 25，Spring Framework 6.2.x） -->
        <spring-boot.version>3.5.3</spring-boot.version>
        <!-- Caffeine 3.2.0（Spring Boot 4.1 BOM 中的最新版本） -->
        <caffeine.version>3.2.0</caffeine.version>
        <!-- MyBatis Spring Boot Starter 3.0.4（兼容 Spring Boot 3.5） -->
        <mybatis-spring-boot.version>3.0.4</mybatis-spring-boot.version>
        <!-- SQLite JDBC 3.49.1.0（最新稳定版） -->
        <sqlite-jdbc.version>3.49.1.0</sqlite-jdbc.version>
        <!-- JUnit 5.12.2（最新稳定版） -->
        <junit.version>5.12.2</junit.version>
        <!-- Lombok 1.18.46 支持 JDK 25 -->
        <lombok.version>1.18.46</lombok.version>
        <!-- JMH -->
        <jmh.version>1.37</jmh.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>com.github.ben-manes.caffeine</groupId>
                <artifactId>caffeine</artifactId>
                <version>${caffeine.version}</version>
            </dependency>
            <dependency>
                <groupId>org.mybatis.spring.boot</groupId>
                <artifactId>mybatis-spring-boot-starter</artifactId>
                <version>${mybatis-spring-boot.version}</version>
            </dependency>
            <dependency>
                <groupId>org.xerial</groupId>
                <artifactId>sqlite-jdbc</artifactId>
                <version>${sqlite-jdbc.version}</version>
            </dependency>
            <!-- 显式管理 Lombok 版本，覆盖 Spring Boot BOM 中的旧版本 -->
            <dependency>
                <groupId>org.projectlombok</groupId>
                <artifactId>lombok</artifactId>
                <version>${lombok.version}</version>
            </dependency>
            <dependency>
                <groupId>io.nexacache</groupId>
                <artifactId>nexacache-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>io.nexacache</groupId>
                <artifactId>nexacache-adapter-mybatis</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- 项目元数据 -->
    <url>https://github.com/yanzhao77/nexacache</url>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
        </license>
    </licenses>

    <developers>
        <developer>
            <id>azir</id>
            <name>azir</name>
            <url>https://github.com/yanzhao77</url>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git://github.com/yanzhao77/nexacache.git</connection>
        <developerConnection>scm:git:ssh://github.com/yanzhao77/nexacache.git</developerConnection>
        <url>https://github.com/yanzhao77/nexacache/tree/master</url>
    </scm>

    <!-- GitHub Packages 发布配置 -->
    <distributionManagement>
        <repository>
            <id>github</id>
            <name>GitHub Packages</name>
            <url>https://maven.pkg.github.com/yanzhao77/nexacache</url>
        </repository>
    </distributionManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <encoding>UTF-8</encoding>
                    <compilerArgs>
                        <!-- 保留方法参数名，供 Spring SpEL (#paramName) 正确解析 -->
                        <arg>-parameters</arg>
                        <!-- 启用 JDK 25 预览特性（Structured Concurrency / Primitive Patterns）-->
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                    <!-- 显式配置 Lombok 作为 annotation processor，确保 JDK 25 下正常工作 -->
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <!-- 运行测试时也启用 preview -->
                    <argLine>--enable-preview</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
